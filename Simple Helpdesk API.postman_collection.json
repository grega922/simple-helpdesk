	"info": {
		"_postman_id": "778c0489-44bb-4d27-9ac5-f9c32f8abbd2",
		"name": "Simple Helpdesk API",
		"description": "Complete API collection for the Simple Helpdesk application.\n\nWorkflow:\n1. Login as user or operator\n2. Create a conversation (user)\n3. View waiting conversations (operator)\n4. Take a conversation (operator)\n5. Exchange messages (both)\n\nThe collection auto-saves the JWT token from login into a variable.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
